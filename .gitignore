# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Jupyter ────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Outputs — large binary / generated files ──────────────────────────────
# Keep CSV outputs (small, human-readable, useful for review)
# Exclude binary/large generated files that should be regenerated from source
outputs/*.parquet
outputs/*.joblib
outputs/simulation_log.parquet

# Keep charts committed if desired; exclude if too large
# outputs/charts/

# ── Raw data archives ─────────────────────────────────────────────────────
# Source zip archives are large (~50–200 MB each); do not commit to git.
# Obtain them from the original Kaggle sources documented in README.md.
*.zip

# ── macOS ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# ── IDEs ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── pytest / coverage ──────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Typing / linting ───────────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Secrets ────────────────────────────────────────────────────────────────
.env
*.key
*.pem

# ── Processed data (regenerated by pipeline) ──────────────────────────────
data/processed/

